<link rel="stylesheet" href="/css/estilos.css">

<div class="pagina-estilos">
    <main class="home-page">
        <section class="home-hero">
            <p class="home-eyebrow">Navegacao do projeto</p>
            <h1>
                <%= titulo %>
            </h1>
            <p class="home-lead">Escolha uma pagina para explorar o conteudo.</p>
        </section>

        <nav class="home-nav" aria-label="Paginas principais">
            <ul class="home-links">
                <% rotas.forEach(function(rota, indice) { %>
                    <li class="home-link-item" style="--item-delay: <%= indice * 0.07 %>s;">
                        <a class="home-link" href="<%= rota.path %>">
                            <span class="home-link-label"><%= rota.label %></span>
                            <span class="home-link-action">Acessar</span>
                        </a>
                    </li>
                    <% }) %>
            </ul>
        </nav>
    </main>
</div>