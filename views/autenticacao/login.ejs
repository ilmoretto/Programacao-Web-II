<link rel="stylesheet" href="/css/login.css">

<section class="login-page">
    <div class="login-shell">
        <article class="login-brand-panel">
            <p class="login-kicker">Area do Aluno</p>
            <h1>Acesse sua conta</h1>
            <p class="login-text">Entre para consultar seus dados, acompanhar atividades do sistema e gerenciar seu
                perfil de forma segura.</p>
        </article>

        <article class="login-card" aria-label="Formulário de login">
            <h2>Entrar</h2>
            <p class="login-subtitle">Use suas credenciais para continuar.</p>

            <form class="login-form" method="post" action="#">
                <div class="login-field">
                    <label for="username">Usuário</label>
                    <input type="text" name="username" id="username" placeholder="seu.usuario" required>
                </div>

                <div class="login-field">
                    <label for="password">Senha</label>
                    <input type="password" name="password" id="password" placeholder="••••••••" required>
                </div>

                <div class="login-actions">
                    <label class="login-remember">
                        <input type="checkbox" name="remember">
                        <span>Lembrar de mim</span>
                    </label>
                    <a href="/contato">Esqueci minha senha</a>
                </div>

                <button type="submit">Acessar conta</button>
            </form>
        </article>
    </div>
</section>