<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<style>
    .container {
        width: 300px;
        display: flex;
        align-items: center;
        background-color: antiquewhite;
        margin: 100px auto;
    }

    label {
        display: block;
        margin-bottom: 5px;
    }
</style>

<body>
    <div class="container">
        <h1>Login</h1>

        <form>
            <div>
                <label for='username'>Usuários</label>
                <input type="text" name="username" id="username">
            </div>

            <div>
                <label for='password'>Senhas</label>
                <input type="password" name="password" id="password">
            </div>
        </form>
    </div>
</body>

</html>