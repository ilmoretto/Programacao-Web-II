<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %></title>
  <link rel="stylesheet" href="/css/estilos.css">
</head>
<body>
  <h1><%= nome %></h1>
  <p><strong>Telefone:</strong> <%= telefone %></p>
  <p><strong>E-mail:</strong> <%= email %></p>
  <hr>

  <h2>Resumo Profissional</h2>
  <p><%= resumo %></p>

  <h2>Identificação</h2>
  <table border="1">
    <thead>
      <tr>
        <th>Campo</th>
        <th>Informação</th>
      </tr>
    </thead>
    <tbody>
      <% identificacao.forEach(function(item) { %>
        <tr>
          <td><%= item.campo %></td>
          <td>
            <% if (item.campo === 'Lattes iD') { %>
              <a href="<%= item.valor %>" target="_blank" rel="noopener noreferrer"><%= item.valor %></a>
            <% } else { %>
              <%= item.valor %>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h2>Formação Acadêmica / Titulação</h2>
  <table border="1">
    <thead>
      <tr>
        <th>Período</th>
        <th>Curso</th>
        <th>Instituição</th>
      </tr>
    </thead>
    <tbody>
      <% formacaoAcademica.forEach(function(item) { %>
        <tr>
          <td><%= item.periodo %></td>
          <td><%= item.curso %></td>
          <td><%= item.instituicao %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h2>Formação Complementar</h2>
  <table border="1">
    <thead>
      <tr>
        <th>Período</th>
        <th>Curso</th>
        <th>Instituição</th>
        <th>Carga horária</th>
      </tr>
    </thead>
    <tbody>
      <% formacaoComplementar.forEach(function(item) { %>
        <tr>
          <td><%= item.periodo %></td>
          <td><%= item.curso %></td>
          <td><%= item.instituicao %></td>
          <td><%= item.cargaHoraria %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h2>Atuação Profissional</h2>
  <table border="1">
    <thead>
      <tr>
        <th>Empresa</th>
        <th>Período</th>
        <th>Vínculo</th>
        <th>Cargo</th>
        <th>Carga horária</th>
      </tr>
    </thead>
    <tbody>
      <% atuacaoProfissional.forEach(function(item) { %>
        <tr>
          <td><%= item.empresa %></td>
          <td><%= item.periodo %></td>
          <td><%= item.vinculo %></td>
          <td><%= item.cargo %></td>
          <td><%= item.cargaHoraria %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
